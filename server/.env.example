# PaiResume 后端配置示例
# 复制为 .env 并修改

# 环境
APP_ENV=development
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
SERVER_PORT=8084

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=pai_resume
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（请替换为随机 Base64 字符串，至少 32 字节）
JWT_SECRET=

# AI（通用 / OpenAI-Compatible）
# 例如：
# GLM-5.1:
# AI_API_KEY=your_glm_api_key
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-5.1
#
# DeepSeek:
# AI_API_KEY=your_deepseek_api_key
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
AI_API_KEY=
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MODEL=glm-5.1
AI_ANALYSIS_MODEL=glm-5.1

# 邮件
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_auth_code
