# ==================== Frontend ====================
VITE_REACT_APP_TITLE=派简历
VITE_PORT=5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8084

# 前端直连 AI（可选）
VITE_AI_API_KEY=your_api_key_here
VITE_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_AI_MODEL=glm-5.1

# ==================== Backend ====================
APP_ENV=development
SERVER_PORT=8084
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175,http://localhost:4173,http://127.0.0.1:4173,http://localhost:63342,http://127.0.0.1:63342,http://[::1]:5173,http://[::1]:5175,http://[::1]:4173

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=pai_resume
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（请替换为随机 Base64 字符串，至少 32 字节）
JWT_SECRET=

# 后端 AI（OpenAI-Compatible）
AI_API_KEY=
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MODEL=glm-5.1
AI_ANALYSIS_MODEL=glm-4.5-air

# 邮件
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_auth_code
