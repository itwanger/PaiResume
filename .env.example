# 应用配置
VITE_REACT_APP_TITLE=派简历
VITE_PORT=5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8084

# AI 配置（可选）- 用于智能简历分析
# 这里使用通用命名，不绑定具体厂商

## GLM / 智谱（OpenAI-Compatible）示例
VITE_AI_API_KEY=your_api_key_here
VITE_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_AI_MODEL=glm-5.1

---

