# 应用配置
VITE_REACT_APP_TITLE=派简历

# AI 配置（可选）- 用于智能简历分析

## 阿里云百炼（通义千问）配置
# 获取 API Key: https://bailian.console.aliyun.com/
VITE_AI_API_KEY=your_api_key_here

# 阿里云百炼 API 端点
VITE_AI_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 通义千问模型
VITE_AI_MODEL=qwen3.5-plus

